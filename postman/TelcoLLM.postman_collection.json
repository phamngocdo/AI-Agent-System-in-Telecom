        {
          "name": "Register User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.environment.get('reuse_test_user') !== 'true') {",
                  "    const runId = `${Date.now()}-${Math.floor(Math.random() * 100000)}`;",
                  "    pm.environment.set('run_id', runId);",
                  "    pm.environment.set('test_email', `postman.${runId}@example.com`);",
                  "    pm.environment.set('test_full_name', 'Postman Test User');",
                  "    pm.environment.unset('access_token');",
                  "    pm.environment.unset('user_id');",
                  "    pm.environment.unset('session_id');",
                  "}",
                  "",
                  "if (!pm.environment.get('test_password')) {",
                  "    pm.environment.set('test_password', 'Test@123456');",
                  "}",
                  "",
                  "if (!pm.environment.get('missing_session_id')) {",
                  "    pm.environment.set('missing_session_id', '000000000000000000000000');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('creates user', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const userId = json._id || json.id;",
                  "",
                  "pm.test('returns public user fields', function () {",
                  "    pm.expect(userId, 'user id').to.be.a('string').and.not.empty;",
                  "    pm.expect(json.email).to.eql(pm.environment.get('test_email'));",
                  "    pm.expect(json.full_name).to.eql(pm.environment.get('test_full_name'));",
                  "    pm.expect(json).to.have.property('created_at');",
                  "});",
                  "",
                  "pm.test('does not leak password hash', function () {",
                  "    pm.expect(json).to.not.have.property('password');",
                  "    pm.expect(json).to.not.have.property('hashed_password');",
                  "});",
                  "",
                  "pm.environment.set('user_id', userId);"
                ]
              }
            }
          ],
